{
  "name": "anisocial-desktop",
  "version": "0.1.0",
  "description": "Desktop-App für AniSocial.de – Die Anime-Community",
  "main": "dist/main.js",
  "scripts": {
    "compile": "tsc",
    "prestart": "tsc",
    "start": "electron .",
    "dev": "tsc && electron .",
    "build": "tsc && electron-builder",
    "build:linux": "tsc && electron-builder --linux",
    "build:win": "tsc && electron-builder --win",
    "build:mac": "tsc && electron-builder --mac"
  },
  "author": {
    "name": "Vando",
    "email": "vando.02800@tutamail.com"
  },
  "license": "MIT",
  "devDependencies": {
    "electron": "^35.7.5",
    "electron-builder": "^26.0.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "electron-window-state": "^5.0.3"
  },
  "build": {
    "appId": "de.anisocial.desktop",
    "productName": "AniSocial",
    "publish": {
      "provider": "github",
      "owner": "VandoOmi",
      "repo": "AniSocialElectron"
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "dist/**",
      "assets/**"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "rpm",
        "pacman",
        "tar.gz"
      ],
      "icon": "assets/icon.png",
      "category": "Network"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.png"
    }
  }
}
